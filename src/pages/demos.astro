---
import Layout from '../layouts/Layout.astro';

const demos = [
  {
    title: "Breakout",
    url: "/breakout",
    description: "Classic block-breaking arcade game with 5 levels, combo system, and particle effects.",
    tags: ["game", "canvas", "interactive"],
  },
  {
    title: "Nokia 3310 Simulator",
    url: "/nokia",
    description: "Relive classic multi-tap texting on an authentic Nokia 3310 phone simulator.",
    tags: ["simulator", "retro", "interactive"],
  },
  {
    title: "Graphene Lattice",
    url: "/graphene",
    description: "Interactive graphene honeycomb lattice. Swipe to radiate waves of color through the crystal structure — adjust wave type, variation, decay, and more.",
    tags: ["canvas", "interactive", "visualization"],
  },
];
---

<Layout
  title="Demos — Neil Gaietto"
  description="Experiments and demos built by Neil Gaietto using AI agents."
>
  <main class="demos-main">
    <h1>Demos</h1>
    <p class="subtitle">Experiments and demos built with AI agents.</p>
    <ul class="demo-list">
      {demos.map((demo) => (
        <li class="demo-card">
          <a href={demo.url} class="demo-title">{demo.title}</a>
          <p class="demo-desc">{demo.description}</p>
          <div class="demo-tags">
            {demo.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  .demos-main {
    max-width: 600px;
    width: 100%;
  }

  .subtitle {
    opacity: 0.75;
    font-style: italic;
    margin-top: -0.5em;
    margin-bottom: 1.75em;
    font-size: 0.95em;
  }

  .demo-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1em;
  }

  .demo-card {
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    padding: 1em 1.25em;
    text-align: left;
    transition: background 0.2s;
  }

  .demo-card:hover,
  .demo-card:focus-within {
    background: rgba(255, 255, 255, 0.12);
  }

  .demo-title {
    font-size: 1.15em;
    font-weight: bold;
    font-style: normal;
    text-decoration: none;
    color: #ffd700;
    display: block;
    margin-bottom: 0.35em;
  }

  .demo-title:hover {
    opacity: 0.85;
    text-decoration: underline;
  }

  .demo-desc {
    margin: 0 0 0.65em;
    font-size: 0.95em;
    opacity: 0.85;
  }

  .demo-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
  }

  .tag {
    font-size: 0.75em;
    background: rgba(255, 215, 0, 0.15);
    border: 1px solid rgba(255, 215, 0, 0.35);
    color: #ffd700;
    border-radius: 4px;
    padding: 0.15em 0.5em;
    letter-spacing: 0.02em;
  }

  @media screen and (orientation: portrait) {
    .demos-main {
      margin: 2em 1.5em;
      max-width: 90vw;
    }
  }

  @media screen and (orientation: landscape) {
    .demos-main {
      max-width: 600px;
    }
  }
</style>
